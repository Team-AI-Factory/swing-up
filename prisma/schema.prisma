generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                String                @unique
  name                 String?
  role                 String                @default("member")
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  subscriptions        Subscription[]
  watchlists           Watchlist[]
  notificationChannels NotificationChannel[]
  telegramAccounts     TelegramAccount[]
  notificationLogs     NotificationLog[]
  paymentEvents        PaymentEvent[]
  adminActions         AdminAction[]         @relation("AdminUserActions")

  @@map("users")
}

model Plan {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String         @unique
  name          String
  priceCents    Int            @default(0) @map("price_cents")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String?   @map("user_id") @db.Uuid
  planId           String?   @map("plan_id") @db.Uuid
  status           String
  currentPeriodEnd DateTime? @map("current_period_end") @db.Timestamptz(6)
  user             User?     @relation(fields: [userId], references: [id])
  plan             Plan?     @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model Watchlist {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  previewOwnerId  String?  @map("preview_owner_id") @db.Uuid
  ticker          String
  company         String?
  assetType       String   @default("equity") @map("asset_type")
  sectorTheme     String?  @map("sector_theme")
  riskPreference  String   @default("balanced") @map("risk_preference")
  alertPreference String   @default("preview_only") @map("alert_preference")
  status          String   @default("active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user            User?    @relation(fields: [userId], references: [id])

  @@map("watchlists")
}

model Alert {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticker           String
  company          String
  action           String
  event            String
  status           String            @default("draft")
  publishedAt      DateTime?         @map("published_at") @db.Timestamptz(6)
  sources          AlertSource[]
  scores           AlertScore[]
  dcfModels        DcfModel[]
  targetPrices     TargetPrice[]
  publicLedger     PublicLedger[]
  patternMatches   PatternMatch[]
  notificationLogs NotificationLog[]
  aiRuns           AiRun[]
  aiCommitteeRuns  AiCommitteeRun[]

  @@map("alerts")
}

model AlertSource {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alertId     String?  @map("alert_id") @db.Uuid
  sourceType  String   @map("source_type")
  receiptUrl  String?  @map("receipt_url")
  summary     String?
  collectedAt DateTime @default(now()) @map("collected_at") @db.Timestamptz(6)
  alert       Alert?   @relation(fields: [alertId], references: [id])

  @@map("alert_sources")
}

model AlertScore {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alertId            String?  @map("alert_id") @db.Uuid
  profitPotential    Int      @map("profit_potential")
  evidenceConfidence Int      @map("evidence_confidence")
  riskLevel          String   @map("risk_level")
  pricedInCheck      String?  @map("priced_in_check")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  alert              Alert?   @relation(fields: [alertId], references: [id])

  @@map("alert_scores")
}

model DcfModel {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alertId     String?  @map("alert_id") @db.Uuid
  assumptions Json     @default("{}")
  output      Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  alert       Alert?   @relation(fields: [alertId], references: [id])

  @@map("dcf_models")
}

model TargetPrice {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alertId     String?  @map("alert_id") @db.Uuid
  lowPrice    Decimal? @map("low_price") @db.Decimal(12, 2)
  highPrice   Decimal? @map("high_price") @db.Decimal(12, 2)
  horizonDays Int      @default(30) @map("horizon_days")
  alert       Alert?   @relation(fields: [alertId], references: [id])

  @@map("target_prices")
}

model PublicLedger {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alertId    String?  @map("alert_id") @db.Uuid
  publicSlug String   @unique @map("public_slug")
  entry      Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  alert      Alert?   @relation(fields: [alertId], references: [id])

  @@map("public_ledger")
}

model PriceSnapshot {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticker     String
  price      Decimal  @db.Decimal(12, 2)
  capturedAt DateTime @default(now()) @map("captured_at") @db.Timestamptz(6)

  @@map("price_snapshots")
}

model RawSignal {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source          String
  ticker          String?
  signalType      String         @default("general") @map("signal_type")
  title           String         @default("Untitled raw signal")
  summary         String         @default("")
  payload         Json           @default("{}")
  receivedAt      DateTime       @default(now()) @map("received_at") @db.Timestamptz(6)
  processedStatus String         @default("new") @map("processed_status")
  importanceHint  String         @default("medium") @map("importance_hint")
  sourceUrl       String?        @map("source_url")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  patternMatches  PatternMatch[]

  @@index([receivedAt(sort: Desc)])
  @@index([source, receivedAt(sort: Desc)])
  @@map("raw_signals")
}

model HistoricalEvent {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticker              String
  companyName         String?        @map("company_name")
  sector              String?
  industry            String?
  eventType           String         @map("event_type")
  eventDate           DateTime       @map("event_date") @db.Date
  title               String?
  summary             String?
  source              String?
  sourceUrl           String?        @map("source_url")
  sourceReceipts      Json           @default("[]") @map("source_receipts")
  priceBefore         Decimal?       @map("price_before") @db.Decimal(12, 2)
  priceAfter1d        Decimal?       @map("price_after_1d") @db.Decimal(12, 2)
  priceAfter3d        Decimal?       @map("price_after_3d") @db.Decimal(12, 2)
  priceAfter7d        Decimal?       @map("price_after_7d") @db.Decimal(12, 2)
  priceAfter30d       Decimal?       @map("price_after_30d") @db.Decimal(12, 2)
  priceAfter90d       Decimal?       @map("price_after_90d") @db.Decimal(12, 2)
  maxGain             Decimal?       @map("max_gain") @db.Decimal(8, 4)
  maxDrawdown         Decimal?       @map("max_drawdown") @db.Decimal(8, 4)
  volumeBeforeEvent   Decimal?       @map("volume_before_event") @db.Decimal(20, 2)
  volumeAfterEvent    Decimal?       @map("volume_after_event") @db.Decimal(20, 2)
  revenueGrowthAtTime Decimal?       @map("revenue_growth_at_time") @db.Decimal(8, 4)
  marginTrend         String?        @map("margin_trend")
  cashFlowTrend       String?        @map("cash_flow_trend")
  debtLevel           String?        @map("debt_level")
  valuationAtTime     String?        @map("valuation_at_time")
  analystChanges      Json           @default("[]") @map("analyst_changes")
  insiderActivity     String?        @map("insider_activity")
  macroSnapshot       Json           @default("{}") @map("macro_snapshot")
  sectorTrend         String?        @map("sector_trend")
  outcomeLabel        String         @default("unknown") @map("outcome_label")
  notes               String?
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  forwardReturns      Json           @default("{}") @map("forward_returns")
  patternTags         Json           @default("[]") @map("pattern_tags")
  patternMatches      PatternMatch[]

  @@index([eventDate(sort: Desc)])
  @@index([ticker, eventDate(sort: Desc)])
  @@index([eventType, eventDate(sort: Desc)])
  @@index([outcomeLabel, eventDate(sort: Desc)])
  @@index([sector, eventDate(sort: Desc)])
  @@map("historical_events")
}

model PatternMatch {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alertId           String?          @map("alert_id") @db.Uuid
  rawSignalId       String?          @map("raw_signal_id") @db.Uuid
  historicalEventId String?          @map("historical_event_id") @db.Uuid
  ticker            String?
  similarity        Decimal          @db.Decimal(5, 2)
  matchScore        Decimal?         @map("match_score") @db.Decimal(5, 2)
  matchReason       String?          @map("match_reason")
  matchedFeatures   Json             @default("[]") @map("matched_features")
  confidenceLabel   String           @default("none") @map("confidence_label")
  notes             String?
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  alert             Alert?           @relation(fields: [alertId], references: [id])
  rawSignal         RawSignal?       @relation(fields: [rawSignalId], references: [id])
  historicalEvent   HistoricalEvent? @relation(fields: [historicalEventId], references: [id])

  @@index([createdAt(sort: Desc)])
  @@index([rawSignalId])
  @@index([historicalEventId])
  @@map("pattern_matches")
}

model SourceHealth {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source         String    @unique
  status         String
  uptime         Decimal?  @db.Decimal(6, 3)
  checkedAt      DateTime  @default(now()) @map("checked_at") @db.Timestamptz(6)
  lastSuccessAt  DateTime? @map("last_success_at") @db.Timestamptz(6)
  responseTimeMs Int?      @map("response_time_ms")
  errorMessage   String?   @map("error_message")
  usage          String?
  notes          String?

  @@map("source_health")
}

model SourceRun {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source             String
  startedAt          DateTime @map("started_at") @db.Timestamptz(6)
  finishedAt         DateTime @map("finished_at") @db.Timestamptz(6)
  status             String
  dryRun             Boolean  @default(true) @map("dry_run")
  recordsChecked     Int      @default(0) @map("records_checked")
  signalsCreated     Int      @default(0) @map("signals_created")
  duplicatesSkipped  Int      @default(0) @map("duplicates_skipped")
  errors             Json     @default("[]")
  sourceHealthStatus String?  @map("source_health_status")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([startedAt(sort: Desc)])
  @@index([source, startedAt(sort: Desc)])
  @@map("source_runs")
}

model MacroSentimentSnapshot {
  id                        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  snapshotType              String   @map("snapshot_type")
  status                    String   @default("partial")
  overallMarketMood         String?  @map("overall_market_mood")
  macroRiskLevel            String?  @map("macro_risk_level")
  macroSupportScore         Int?     @map("macro_support_score")
  sentimentSupportScore     Int?     @map("sentiment_support_score")
  riskOffPenalty            Int?     @map("risk_off_penalty")
  confidenceAdjustment      Int?     @map("confidence_adjustment")
  profitPotentialAdjustment Int?     @map("profit_potential_adjustment")
  summary                   String   @default("")
  dataFreshness             Json     @default("{}") @map("data_freshness")
  sourceReceipts            Json     @default("[]") @map("source_receipts")
  payload                   Json     @default("{}")
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)])
  @@index([snapshotType, createdAt(sort: Desc)])
  @@map("macro_sentiment_snapshots")
}

model NotificationChannel {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String? @map("user_id") @db.Uuid
  channelType String  @map("channel_type")
  destination String
  isEnabled   Boolean @default(true) @map("is_enabled")
  user        User?   @relation(fields: [userId], references: [id])

  @@map("notification_channels")
}

model TelegramAccount {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String?   @map("user_id") @db.Uuid
  telegramUserId String?   @unique @map("telegram_user_id")
  handle         String?
  linkedAt       DateTime? @map("linked_at") @db.Timestamptz(6)
  user           User?     @relation(fields: [userId], references: [id])

  @@map("telegram_accounts")
}

model NotificationLog {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  alertId     String?   @map("alert_id") @db.Uuid
  channelType String    @map("channel_type")
  status      String
  sentAt      DateTime? @default(now()) @map("sent_at") @db.Timestamptz(6)
  user        User?     @relation(fields: [userId], references: [id])
  alert       Alert?    @relation(fields: [alertId], references: [id])

  @@map("notification_logs")
}

model PaymentEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  provider  String
  eventType String   @map("event_type")
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User?    @relation(fields: [userId], references: [id])

  @@map("payment_events")
}

model AdminAction {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminUserId String?  @map("admin_user_id") @db.Uuid
  action      String
  subjectType String?  @map("subject_type")
  subjectId   String?  @map("subject_id") @db.Uuid
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  adminUser   User?    @relation("AdminUserActions", fields: [adminUserId], references: [id])

  @@map("admin_actions")
}

model AiRun {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alertId    String?     @map("alert_id") @db.Uuid
  runType    String      @map("run_type")
  provider   String      @default("stub")
  status     String
  output     Json        @default("{}")
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  alert      Alert?      @relation(fields: [alertId], references: [id])
  aiCostLogs AiCostLog[]

  @@map("ai_runs")
}

model AiCostLog {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  aiRunId            String?  @map("ai_run_id") @db.Uuid
  model              String
  inputTokens        Int      @default(0) @map("input_tokens")
  outputTokens       Int      @default(0) @map("output_tokens")
  estimatedCostCents Int      @default(0) @map("estimated_cost_cents")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  aiRun              AiRun?   @relation(fields: [aiRunId], references: [id])

  @@map("ai_cost_logs")
}

model AiCommitteeRun {
  id                  String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateAlertId    String?                  @map("candidate_alert_id") @db.Uuid
  alertId             String?                  @map("alert_id") @db.Uuid
  status              String
  runMode             String                   @map("run_mode")
  dryRun              Boolean                  @default(true) @map("dry_run")
  agentIds            Json                     @default("[]") @map("agent_ids")
  finalRecommendation String?                  @map("final_recommendation")
  selectedActionLabel String?                  @map("selected_action_label")
  scoreOutputs        Json                     @default("{}") @map("score_outputs")
  riskLevel           String?                  @map("risk_level")
  complianceWarnings  Json                     @default("[]") @map("compliance_warnings")
  missingData         Json                     @default("[]") @map("missing_data")
  modelProvider       String                   @default("unknown") @map("model_provider")
  modelNames          Json                     @default("[]") @map("model_names")
  tokenEstimate       Int?                     @map("token_estimate")
  estimatedCostCents  Int                      @default(0) @map("estimated_cost_cents")
  output              Json                     @default("{}")
  request             Json                     @default("{}")
  startedAt           DateTime                 @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt          DateTime?                @map("finished_at") @db.Timestamptz(6)
  error               String?
  createdAt           DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  alert               Alert?                   @relation(fields: [alertId], references: [id])
  agentResults        AiCommitteeAgentResult[]

  @@index([createdAt(sort: Desc)])
  @@index([candidateAlertId, createdAt(sort: Desc)])
  @@index([alertId, createdAt(sort: Desc)])
  @@map("ai_committee_runs")
}

model AiCommitteeAgentResult {
  id                   String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId                String         @map("run_id") @db.Uuid
  agentId              String         @map("agent_id")
  status               String
  verdict              String?
  confidence           Int?
  missingData          Json           @default("[]") @map("missing_data")
  keyFindings          Json           @default("[]") @map("key_findings")
  concerns             Json           @default("[]")
  suggestedActionLabel String?        @map("suggested_action_label")
  modelProvider        String         @default("unknown") @map("model_provider")
  modelName            String?        @map("model_name")
  tokenEstimate        Int?           @map("token_estimate")
  estimatedCostCents   Int            @default(0) @map("estimated_cost_cents")
  output               Json           @default("{}")
  error                String?
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  run                  AiCommitteeRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([agentId])
  @@map("ai_committee_agent_results")
}

model RawDataObject {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source             String
  assetType          String   @map("asset_type")
  symbol             String?
  normalizedSymbol   String?  @map("normalized_symbol")
  dataType           String   @map("data_type")
  r2Key              String   @map("r2_key")
  contentHash        String   @unique @map("content_hash")
  observedAt         DateTime @default(now()) @map("observed_at") @db.Timestamptz(6)
  storedAt           DateTime @default(now()) @map("stored_at") @db.Timestamptz(6)
  byteSize           Int      @default(0) @map("byte_size")
  recordCount        Int?     @map("record_count")
  dateRangeStart     DateTime? @map("date_range_start") @db.Date
  dateRangeEnd       DateTime? @map("date_range_end") @db.Date
  status             String   @default("stored")
  providerPlanStatus String?  @map("provider_plan_status")
  sourceUrl          String?  @map("source_url")
  receiptUrl         String?  @map("receipt_url")
  metadata           Json     @default("{}")

  @@index([source])
  @@index([assetType])
  @@index([normalizedSymbol])
  @@index([dataType])
  @@index([observedAt(sort: Desc)])
  @@index([dateRangeStart, dateRangeEnd])
  @@index([contentHash])
  @@map("raw_data_objects")
}

model MarketPriceSnapshot {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticker                String
  provider              String
  sourceUrl             String?  @map("source_url")
  latestPrice           Decimal? @map("latest_price") @db.Decimal(20, 6)
  currency              String?
  volume                Decimal? @db.Decimal(24, 4)
  averageVolume         Decimal? @map("average_volume") @db.Decimal(24, 4)
  priceChange1d         Decimal? @map("price_change_1d") @db.Decimal(14, 6)
  priceChange5d         Decimal? @map("price_change_5d") @db.Decimal(14, 6)
  priceChange20d        Decimal? @map("price_change_20d") @db.Decimal(14, 6)
  previousClose         Decimal? @map("previous_close") @db.Decimal(20, 6)
  open                  Decimal? @db.Decimal(20, 6)
  high                  Decimal? @db.Decimal(20, 6)
  low                   Decimal? @db.Decimal(20, 6)
  timestampFromProvider DateTime @map("timestamp_from_provider") @db.Timestamptz(6)
  capturedAt            DateTime @default(now()) @map("captured_at") @db.Timestamptz(6)
  marketSession         String?  @map("market_session")
  rawStoredInR2         Boolean  @default(false) @map("raw_stored_in_r2")
  r2ObjectKey           String?  @map("r2_object_key")
  dataQuality           String   @default("partial") @map("data_quality")
  unavailableReason     String?  @map("unavailable_reason")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([ticker, provider, timestampFromProvider])
  @@index([ticker, capturedAt(sort: Desc)])
  @@index([ticker, dataQuality, capturedAt(sort: Desc)])
  @@map("market_price_snapshots")
}
